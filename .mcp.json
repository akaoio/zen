{
  "mcpServers": {
    "chrome-devtools": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest", "--headless"],
      "env": {},
      "tools": ["*"]
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"],
      "env": {},
      "tools": ["*"]
    },
    "zen": {
      "type": "stdio",
      "command": "node",
      "args": ["./lib/mcp.js"],
      "env": {},
      "tools": ["*"]
    }
  }
}
